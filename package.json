{
  "name": "vite-figma-plugin",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "npm run watch",
    "dev:ui": "vite",
    "prebuild": "npm run clean",
    "build": "npm run typecheck && vite build && npm run build:code && npm run verify:dist",
    "build:code": "esbuild lib/code.ts --bundle --format=iife --target=es2020 --minify --tsconfig=tsconfig.plugin.json --outfile=dist/code.js",
    "prewatch": "npm run clean",
    "watch": "concurrently --kill-others-on-fail --names types,ui,code \"tsc -b --watch --preserveWatchOutput\" \"npm run watch:ui\" \"npm run watch:code\"",
    "watch:ui": "node scripts/watch-ui.mjs",
    "watch:code": "esbuild lib/code.ts --bundle --format=iife --target=es2020 --tsconfig=tsconfig.plugin.json --outfile=dist/code.js --watch --sourcemap=inline",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:dist": "node scripts/verify-dist.mjs",
    "clean": "rimraf dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@figma/plugin-typings": "^1.131.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "acorn": "^8.17.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "lightningcss": "^1.32.0",
    "parse5": "^8.0.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
